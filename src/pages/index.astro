---
import Layout from "@/layouts/Layout.astro";

const introLinks = {
  projects: "/from-scratch",
  blogs: "/blogs",
  books: "https://www.goodreads.com/user/show/189947877-biraj",
};

const exploringItems = [
  {
    href: "https://github.com/biraj21/ex-coding-agent",
    label: "elixir & agent harnesses",
    external: true,
  },
  { label: "real-time voice AI infra" },
  { label: "multi-agent systems" },
];

const navLinks = [
  { href: "https://x.com/biraj21_", label: "X", external: true },
  { href: "/resume", label: "resume" },
  { href: "/blogs", label: "blog" },
  { href: "/from-scratch", label: "projects" },
  { href: "https://github.com/biraj21", label: "github", external: true },
  { href: "mailto:biraj.pub@gmail.com", label: "email" },
];

const allPosts = Object.values(import.meta.glob("./blogs/*.md", { eager: true }));

const posts = allPosts
  .filter((post) => !post.url?.includes(".draft"))
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime())
  .slice(0, 3)
  .map((post) => ({
    ...post,
    formattedDate: new Date(post.frontmatter.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }),
  }));
---

<Layout title="Biraj">
  <main class="home">
    <h1>biraj - wannabe founder</h1>

    <section class="intro">
      <p>
        i sometimes build things <a href={introLinks.projects}>from scratch</a> to understand how they work, write <a
          href={introLinks.blogs}>blogs</a
        >, and read <a href={introLinks.books} target="_blank" rel="noreferrer">books</a>.
      </p>

      <p>
        i also play chess (1700 rapid on <a href="https://www.chess.com/member/biraj21" target="_blank" rel="noreferrer"
          >chess.com</a
        >), play badminton, and spend a fair amount of time fucking around hoping for the divine find out.
      </p>

      <p>
        was also part of <a href="https://lossfunk.com/residency/" target="_blank" rel="noreferrer"
          >Lossfunk Residency</a
        >, batch 6.
      </p>
    </section>

    <section class="currently-exploring">
      <h2>$ currently exploring</h2>
      <ul>
        {
          exploringItems.map((item) => (
            <li>
              {item.href ? (
                <a href={item.href} target={item.external ? "_blank" : undefined} rel="noreferrer">
                  {item.label}
                </a>
              ) : (
                item.label
              )}
            </li>
          ))
        }
      </ul>

      <p>
        also check out <a href="https://www.hangingpiece.com" target="_blank" rel="noreferrer">Hanging Piece</a>, an AI
        chess coach i built.
      </p>
    </section>

    {
      posts.length > 0 && (
        <section class="latest-posts">
          <h2>$ latest posts</h2>
          <ul>
            {posts.map((post) => (
              <li>
                <a href={post.url}>{post.frontmatter.title}</a>
                <span class="post-date">{post.formattedDate}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <nav class="home-nav" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </main>

  <style>
    .home {
      max-width: 500px;
      margin: 0 auto;
      padding: 3rem 1rem;
      line-height: 1.6;
      text-align: left;
    }

    .home h1 {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
      font-weight: normal;
      border-bottom: 2px solid var(--accent-color);
      padding-bottom: 0.5rem;
    }

    .home p {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .home section + section,
    .home-nav {
      margin-top: 2rem;
    }

    .home h2 {
      font-size: 1.2rem;
      margin-bottom: 1rem;
      font-weight: normal;
      border-bottom: 1px solid var(--accent-color);
      padding-bottom: 0.3rem;
    }

    .currently-exploring ul {
      margin: 0;
      padding-left: 2rem;
    }

    .latest-posts ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .latest-posts li {
      margin-bottom: 0.5rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }

    .latest-posts .post-date {
      color: #666;
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .home-nav {
      border-top: 1px solid var(--accent-color);
      padding-top: 1rem;
    }

    .home-nav a {
      display: inline-block;
      margin-right: 1rem;
      margin-bottom: 0.5rem;
      padding: 0.2rem 0.5rem;
      border: 1px solid var(--accent-color);
      text-decoration: none;
      font-family: inherit;
    }

    @media (max-width: 600px) {
      body {
        padding: 1rem;
      }

      .home {
        padding: 1rem;
      }

      .home h1 {
        font-size: 1.3rem;
      }

      .home h2 {
        font-size: 1.1rem;
      }

      .latest-posts li {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.2rem;
      }

      .home-nav a {
        margin-right: 0.5rem;
      }
    }
  </style>
</Layout>
