---
import Layout from "@/layouts/Layout.astro";

const introLinks = {
  projects: "/from-scratch",
  blogs: "/blogs",
  books: "https://www.goodreads.com/user/show/189947877-biraj",
};

const navLinks = [
  { href: "https://x.com/biraj21_", label: "twitter", external: true },
  { href: "/resume", label: "resume" },
  { href: "/blogs", label: "blog" },
  { href: "/from-scratch", label: "projects" },
  { href: "https://github.com/biraj21", label: "github", external: true },
  { href: "mailto:biraj.pub@gmail.com", label: "email" },
];

// const allPosts = Object.values(import.meta.glob("./blogs/*.md", { eager: true }));

// const posts = allPosts
//   .filter((post) => !post.url?.includes(".draft"))
//   .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime())
//   .slice(0, 2)
//   .map((post) => ({
//     ...post,
//     formattedDate: new Date(post.frontmatter.pubDate).toLocaleDateString("en-US", {
//       year: "numeric",
//       month: "short",
//       day: "numeric",
//     }),
//   }));
---

<Layout title="Biraj">
  <main class="home">
    <h1>biraj - building <a href="https://shellular.dev" target="_blank">shellular.dev</a></h1>

    <section class="intro">
      <img src="/images/me.jpeg" alt="Biraj" class="profile-image" />

      <p>
        i sometimes build things <a href={introLinks.projects}>from scratch</a> to understand how they work, write <a
          href={introLinks.blogs}>blogs</a
        >, and read <a href={introLinks.books} target="_blank" rel="noreferrer">books</a>.
      </p>

      <p>
        i also play chess (1700 rapid on <a href="https://www.chess.com/member/biraj21" target="_blank" rel="noreferrer"
          >chess.com</a
        >), play badminton, and spend a fair amount of time fucking around hoping for the divine find out.
      </p>

      <p>
        was part of <a href="https://lossfunk.com/residency/" target="_blank" rel="noreferrer">Lossfunk Residency</a>,
        batch 6.
      </p>
    </section>

    <section class="currently-exploring">
      <h2>$ currently exploring</h2>

      <p>
        i'm building <a href="https://shellular.dev/" target="_blank" rel="noreferrer">Shellular</a>, an app that brings
        your dev environment (terminals, browser dev tools, & coding agents like Claude Code, Codex, OpenCode etc.) on
        your phone.
      </p>

      <p>
        also check out <a href="https://www.hangingpiece.com" target="_blank" rel="noreferrer">Hanging Piece</a>, an AI
        chess coach i've built.
      </p>
    </section>
    <!-- 
    {
      posts.length > 0 && (
        <section class="latest-posts">
          <h2>$ latest posts</h2>
          <ul>
            {posts.map((post) => (
              <li>
                <a href={post.url}>{post.frontmatter.title}</a>
                <span class="post-date">{post.formattedDate}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    } -->

    <nav class="home-nav" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </main>

  <style>
    .home {
      max-width: 600px;
      margin: 0 auto;
      padding: 3rem 1rem;
      line-height: 1.6;
      text-align: left;
    }

    .home h1 {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
      font-weight: normal;
      border-bottom: 2px solid var(--accent-color);
      padding-bottom: 0.5rem;
    }

    .intro {
      position: relative;
    }

    .profile-image {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      float: right;
      margin-left: 1.5rem;
      margin-bottom: 1rem;
      shape-outside: circle(50%);
    }

    .home p {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .home section + section,
    .home-nav {
      margin-top: 2rem;
    }

    .home h2 {
      font-size: 1.2rem;
      margin-bottom: 1rem;
      font-weight: normal;
      border-bottom: 1px solid var(--accent-color);
      padding-bottom: 0.3rem;
    }

    .latest-posts ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .latest-posts li {
      margin-bottom: 0.5rem;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }

    .latest-posts .post-date {
      color: #666;
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .home-nav {
      border-top: 1px solid var(--accent-color);
      padding-top: 1rem;
    }

    .home-nav a {
      display: inline-block;
      margin-right: 1rem;
      margin-bottom: 0.5rem;
      padding: 0.2rem 0.5rem;
      border: 1px solid var(--accent-color);
      text-decoration: none;
      font-family: inherit;
    }

    @media (max-width: 600px) {
      body {
        padding: 1rem;
      }

      .home {
        padding: 1rem;
      }

      .profile-image {
        width: 100px;
        height: 100px;
        margin-left: 1rem;
      }

      .home h1 {
        font-size: 1.3rem;
      }

      .home h2 {
        font-size: 1.1rem;
      }

      .latest-posts li {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.2rem;
      }

      .home-nav a {
        margin-right: 0.5rem;
      }
    }
  </style>
</Layout>
